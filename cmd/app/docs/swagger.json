{
    "swagger": "2.0",
    "info": {
        "description": "Detect-first, escalate-later web scraper with LLM processing.",
        "title": "Greenclaw API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/extract": {
            "post": {
                "description": "Scrapes the given URL and returns structured content. For YouTube URLs, also returns transcript and LLM processing results.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "extract"
                ],
                "summary": "Extract content from a URL",
                "parameters": [
                    {
                        "description": "URL to extract",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/server.extractRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.httpResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/server.errorResponse"
                        }
                    }
                }
            }
        },
        "/extract/stream": {
            "post": {
                "description": "Same as /extract but streams chunk-level progress events via Server-Sent Events while the LLM processes the transcript. Final result is sent as an \"result\" event.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "extract"
                ],
                "summary": "Extract content from a URL with SSE progress streaming",
                "parameters": [
                    {
                        "description": "URL to extract",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/server.extractRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/server.httpResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/server.errorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "server.errorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "server.extractRequest": {
            "type": "object",
            "required": [
                "url"
            ],
            "properties": {
                "num_ctx": {
                    "type": "integer",
                    "example": 8192
                },
                "styles": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "summary",
                        "takeaways"
                    ]
                },
                "url": {
                    "type": "string",
                    "example": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
                }
            }
        },
        "server.httpResult": {
            "type": "object",
            "properties": {
                "channel_name": {
                    "type": "string"
                },
                "content": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "content_type": {
                    "$ref": "#/definitions/store.ContentType"
                },
                "description": {
                    "type": "string"
                },
                "duration": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                },
                "fetched_at": {},
                "language_code": {
                    "type": "string"
                },
                "links": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "model": {
                    "type": "string"
                },
                "num_ctx": {
                    "type": "integer"
                },
                "style": {
                    "type": "string"
                },
                "styles": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "title": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "video_id": {
                    "type": "string"
                }
            }
        },
        "store.ContentType": {
            "type": "string",
            "enum": [
                "html",
                "json",
                "xml",
                "binary",
                "youtube_video",
                "youtube_playlist",
                "youtube_channel"
            ],
            "x-enum-varnames": [
                "ContentHTML",
                "ContentJSON",
                "ContentXML",
                "ContentBinary",
                "ContentYouTubeVideo",
                "ContentYouTubePlaylist",
                "ContentYouTubeChannel"
            ]
        }
    }
}