{
    "swagger": "2.0",
    "info": {
        "description": "Detect-first, escalate-later web scraper with LLM processing.",
        "title": "Greenclaw API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/extract/graph": {
            "post": {
                "description": "Given a YouTube URL (video already extracted), runs LLM entity/relationship extraction and populates the graph.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "extract"
                ],
                "summary": "Build knowledge graph",
                "parameters": [
                    {
                        "description": "YouTube URL",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/service.BuildGraphReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.BuildGraphResp"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/extract/youtube": {
            "post": {
                "description": "Given a YouTube URL, fetches (or transcribes) the transcript and stores it in ArangoDB.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "extract"
                ],
                "summary": "Extract YouTube transcript",
                "parameters": [
                    {
                        "description": "YouTube URL",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/service.ExtractYoutubeReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.ExtractYoutubeResp"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "service.BuildGraphReq": {
            "type": "object",
            "properties": {
                "youtubeURL": {
                    "type": "string"
                }
            }
        },
        "service.BuildGraphResp": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "edges_added": {
                    "type": "integer"
                },
                "entities_added": {
                    "type": "integer"
                },
                "video_id": {
                    "type": "string"
                }
            }
        },
        "service.ExtractYoutubeReq": {
            "type": "object",
            "properties": {
                "youtubeURL": {
                    "type": "string"
                }
            }
        },
        "service.ExtractYoutubeResp": {
            "type": "object",
            "properties": {
                "duration": {
                    "type": "string"
                },
                "language": {
                    "type": "string"
                },
                "stored": {
                    "type": "boolean"
                },
                "title": {
                    "type": "string"
                },
                "transcript": {
                    "type": "string"
                },
                "video_id": {
                    "type": "string"
                }
            }
        }
    }
}